{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 0,
    "patch": 0
  },
  "include": [
    "Base.json"
  ],
  "configurePresets": [
    {
      "name": "windows",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "inherits": [
        "base-preset"
      ],
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cmakeExecutable": "C:\\Program Files\\CMake\\bin\\cmake.exe",
      "cacheVariables": {
        "CPM_SOURCE_CACHE": "${sourceDir}/build/cpm-cache",
        "CPM_USE_NAMED_CACHE_DIRECTORIES": "ON"
      }
    },
    {
      "name": "windows-x64",
      "hidden": true,
      "inherits": [
        "windows"
      ],
      "architecture": "x64",
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "intelliSenseMode": "windows-msvc-x64"
        }
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ]
}
